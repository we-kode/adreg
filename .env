IMAGE_ADMIN=w3kod3/wekode.adreg.admin:0.0.4
PORT_ADMIN=8081
MIGRATE_ADMIN=True

IMAGE_REGISTER=w3kod3/wekode.adreg:0.0.4
PORT_REGISTER=8082
MIGRATE_REGISTER=False

# user id to be used. 0 if root
UID=1001
GID=1001

# Mail Config
SMTP__Host=
SMTP__Port=
SMTP__User=
SMTP__Password=
SMTP__From=
SMTP__UseSsl=true
#SMTP__RegistrationText=

# Active Directory / LDAP settings
# AD__LdapUrl supports formats: host, host:port, ldap://host:389 or ldaps://host:636
# Examples:
# AD__LdapUrl=ldap://dc01.example.local:389
# AD__LdapUrl=ldaps://dc01.example.local:636
AD__LdapUrl=
AD__BindDn=
AD__BindPassword=
AD__SearchBase=
AD__UsersContainer=
# If true, the LDAP server certificate will not be validated. Only for testing.
AD__AllowInvalidCertificate=false
