IMAGE_ADMIN=w3kod3/wekode.adreg.admin:0.0.4
PORT_ADMIN=8081
MIGRATE_ADMIN=True

IMAGE_REGISTER=w3kod3/wekode.adreg:0.0.4
PORT_REGISTER=8082
MIGRATE_REGISTER=False

# user id to be used. 0 if root
UID=1001
GID=1001

# Link Generation Config
LinkBaseUrl=

# Mail Config
SMTP__Host=
SMTP__Port=
SMTP__User=
SMTP__Password=
SMTP__From=
SMTP__UseSsl=true
#SMTP__RegistrationText=

# ----------------------------------------------------------------------------
# Directory settings (Active Directory or LDAP, e.g. OpenLDAP)
# ----------------------------------------------------------------------------
# AD__ServerType selects the directory backend. Active Directory is prioritized
# and remains the default if this value is omitted or set to an unknown value.
#   ActiveDirectory : Microsoft Active Directory (sAMAccountName, unicodePwd, ...)
#   Ldap            : generic LDAP server such as OpenLDAP (uid, userPassword, ...)
AD__ServerType=ActiveDirectory

# AD__LdapUrl supports the formats: host, host:port, ldap://host:389 or ldaps://host:636
# Examples:
# AD__LdapUrl=ldap://dc01.example.local:389
# AD__LdapUrl=ldaps://dc01.example.local:636
# AD__LdapUrl=ldap://openldap.example.org:389
AD__LdapUrl=

# Bind credentials. The bind account needs permission to create users in
# AD__UsersContainer and to modify the `member` attribute on AD__GroupsContainer.
AD__BindDn=
AD__BindPassword=

# Base DN used as the root for searches, e.g. DC=example,DC=local or dc=example,dc=org.
AD__SearchBase=

# Container/OU for new users. Either relative to SearchBase ("OU=Users") or a full DN.
AD__UsersContainer=

# Container/OU for groups. Optional - falls back to SearchBase. Relative or full DN.
# AD__GroupsContainer=

# Optional: comma-separated object classes that identify user entries.
# Defaults: "user" for ActiveDirectory, "inetOrgPerson" for Ldap.
# AD__UsersObjectClasses=

# Optional: comma-separated object classes that identify group entries.
# Defaults: "group" for ActiveDirectory, "groupOfNames" for Ldap.
# AD__GroupsObjectClasses=

# Optional: override for the username attribute.
# Defaults: "sAMAccountName" for ActiveDirectory, "uid" for Ldap.
# AD__UsernameAttribute=

# Optional: sender address written to the user's `mail` attribute.
# Falls back to the user's own address when left empty.
# AD__InvitationSenderEmail=

# If true, the LDAP server certificate will not be validated. Use only for testing.
AD__AllowInvalidCertificate=false
