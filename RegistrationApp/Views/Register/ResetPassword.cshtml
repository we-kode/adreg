@using Shared.Models
@model PasswordResetLink

@{
    Layout = "_Layout";
    var error = ViewBag.Error as string;
}

<h2 class="mt-3">Passwort zurücksetzen</h2>

<div class="card mt-3 shadow-sm">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <p class="text-muted">
            Bitte vergib ein neues Passwort
            @if (!string.IsNullOrWhiteSpace(Model.Username))
            {
                <span>für <strong>@Model.Username</strong></span>
            }.
            Der Link kann nur einmal verwendet werden.
        </p>

        <form method="post" id="resetForm">
            <div class="mb-3">
                <label for="password" class="form-label">Neues Passwort</label>
                <input id="password" type="password" name="password" class="form-control" autocomplete="new-password" />
            </div>
            <div class="mb-3">
                <label for="confirm" class="form-label">Passwort bestätigen</label>
                <input id="confirm" type="password" name="confirm" class="form-control" autocomplete="new-password" />
            </div>

            <ul class="text-muted small mb-3">
                <li>Mindestens 8 Zeichen</li>
                <li>Großbuchstaben und Kleinbuchstaben</li>
                <li>Mindestens eine Zahl</li>
                <li>Mindestens ein Sonderzeichen</li>
            </ul>

            <div id="validation" class="text-danger mb-3"></div>

            <button id="submitBtn" type="submit" class="btn btn-primary" disabled>Aktualisieren</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const pwd = document.getElementById('password');
        const conf = document.getElementById('confirm');
        const submitBtn = document.getElementById('submitBtn');
        const validation = document.getElementById('validation');

        function validateForm() {
            const p = pwd.value;
            const c = conf.value;

            const msgs = [];
            if (!p) msgs.push('Passwort erforderlich');
            if (p && p.length < 8) msgs.push('Passwort muss mindestens 8 Zeichen haben');
            if (p && !/[A-Z]/.test(p)) msgs.push('Passwort benötigt einen Großbuchstaben');
            if (p && !/[a-z]/.test(p)) msgs.push('Passwort benötigt einen Kleinbuchstaben');
            if (p && !/[0-9]/.test(p)) msgs.push('Passwort benötigt eine Zahl');
            if (p && !/[^a-zA-Z0-9]/.test(p)) msgs.push('Passwort benötigt ein Sonderzeichen');
            if (p && c && p !== c) msgs.push('Passwörter stimmen nicht überein');
            if (p && !c) msgs.push('Bitte Passwort bestätigen');

            validation.innerText = msgs.join('; ');
            submitBtn.disabled = msgs.length > 0;
        }

        pwd.addEventListener('input', validateForm);
        conf.addEventListener('input', validateForm);
        validateForm();
    </script>
}
