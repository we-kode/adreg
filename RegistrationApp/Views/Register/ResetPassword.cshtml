@using Shared.Models
@model PasswordResetLink

@{
    Layout = "_Layout";
    var error = ViewBag.Error as string;

    // Effective password policy, resolved server-side (live directory policy or configured fallback).
    int minLength = ViewBag.MinLength ?? 8;
    bool requireComplexity = ViewBag.RequireComplexity ?? true;
    string displayName = (string?)ViewBag.DisplayName ?? string.Empty;
}

<h2 class="mt-3">Passwort zurücksetzen</h2>

<div class="card mt-3 shadow-sm">
    <div class="card-body">
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        <p class="text-muted">
            Bitte vergib ein neues Passwort
            @if (!string.IsNullOrWhiteSpace(Model.Username))
            {
                <span>für <strong>@Model.Username</strong></span>
            }.
            Der Link kann nur einmal verwendet werden.
        </p>

        <form method="post" id="resetForm">
            <div class="mb-3">
                <label for="password" class="form-label">Neues Passwort</label>
                <input id="password" type="password" name="password" class="form-control" autocomplete="new-password" />
            </div>
            <div class="mb-3">
                <label for="confirm" class="form-label">Passwort bestätigen</label>
                <input id="confirm" type="password" name="confirm" class="form-control" autocomplete="new-password" />
            </div>

            <ul id="policyHints" class="text-muted small mb-3">
                <li>Mindestens @minLength Zeichen</li>
                @if (requireComplexity)
                {
                    <li>Großbuchstaben und Kleinbuchstaben</li>
                    <li>Mindestens eine Zahl</li>
                    <li>Mindestens ein Sonderzeichen</li>
                }
                <li>Darf nicht den Benutzernamen@(string.IsNullOrWhiteSpace(displayName) ? "" : " oder Namen") enthalten</li>
            </ul>

            <div id="validation" class="text-danger mb-3"></div>

            <button id="submitBtn" type="submit" class="btn btn-primary" disabled>Aktualisieren</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const pwd = document.getElementById('password');
        const conf = document.getElementById('confirm');
        const submitBtn = document.getElementById('submitBtn');
        const validation = document.getElementById('validation');
        const username = @Json.Serialize(Model.Username);
        const displayName = @Json.Serialize(displayName);

        // Policy injected server-side so client validation matches the rendered hints exactly.
        const policy = { minLength: @minLength, requireComplexity: @(requireComplexity ? "true" : "false") };

        function validateForm() {
            const p = pwd.value;
            const c = conf.value;

            const msgs = [];
            if (!p) msgs.push('Passwort erforderlich');

            if (p) {
                if (p.length < policy.minLength) msgs.push(`Passwort muss mindestens ${policy.minLength} Zeichen haben`);
                if (policy.requireComplexity) {
                    if (!/[A-Z]/.test(p)) msgs.push('Passwort benötigt einen Großbuchstaben');
                    if (!/[a-z]/.test(p)) msgs.push('Passwort benötigt einen Kleinbuchstaben');
                    if (!/[0-9]/.test(p)) msgs.push('Passwort benötigt eine Zahl');
                    if (!/[^a-zA-Z0-9]/.test(p)) msgs.push('Passwort benötigt ein Sonderzeichen');
                }
                if (username && p.toLowerCase().includes(username.toLowerCase())) msgs.push('Passwort darf nicht den Benutzernamen enthalten');
                if (displayName && p.toLowerCase().includes(displayName.toLowerCase())) msgs.push('Passwort darf nicht den Namen enthalten');
            }

            if (p && c && p !== c) msgs.push('Passwörter stimmen nicht überein');
            if (p && !c) msgs.push('Bitte Passwort bestätigen');

            validation.innerText = msgs.join('; ');
            submitBtn.disabled = msgs.length > 0;
        }

        pwd.addEventListener('input', validateForm);
        conf.addEventListener('input', validateForm);
        validateForm();
    </script>
}
