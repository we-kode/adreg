<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Admin Portal</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">

            <a class="navbar-brand" href="/Admin">Admin Portal</a>

            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div class="d-flex">
                    <a class="btn btn-outline-light btn-sm me-2" href="/Admin/CreateLink">➕ New Link</a>
                    <a class="btn btn-outline-light btn-sm me-2" href="/Admin/Invitations">📨 Invitations</a>
                    <a class="btn btn-outline-light btn-sm me-2" href="/Admin/CreateGroup">🗂️ New Group</a>
                    <a class="btn btn-outline-light btn-sm me-2" href="/Admin/ManageMails">✉️ Manage Mails</a>
                    <a class="btn btn-outline-light btn-sm me-2" href="/Admin/ManageTemplates">📝 Mail Templates</a>
                    <a class="btn btn-outline-danger btn-sm" href="/Auth/Logout">Logout</a>
                </div>
            }
        </div>
    </nav>

    <div class="container mt-4">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>
