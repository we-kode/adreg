@{
    Layout = "_Layout";
}

<h2 class="mb-4">Manage Directory - Groups / Users</h2>

<div class="mb-3">
    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">← Pending Registrations</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label">View</label>
                    <select id="viewSelect" class="form-select">
                        <option value="groups">Groups</option>
                        <option value="users">Users</option>
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Filter</label>
                    <input id="filterInput" class="form-control" placeholder="search by name" />
                </div>

                <div class="d-grid">
                    <button id="loadBtn" class="btn btn-primary">Load</button>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h5 id="listTitle">Groups</h5>
                <ul id="itemList" class="list-group list-group-flush" style="max-height:60vh; overflow:auto"></ul>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 id="detailTitle">Details</h5>
                <div id="detailsArea">Select a group or user to load related items.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const loadBtn = document.getElementById('loadBtn');
        const viewSelect = document.getElementById('viewSelect');
        const filterInput = document.getElementById('filterInput');
        const itemList = document.getElementById('itemList');
        const detailTitle = document.getElementById('detailTitle');
        const detailsArea = document.getElementById('detailsArea');
        const listTitle = document.getElementById('listTitle');

        function clearDetails() {
            detailsArea.innerHTML = '';
        }

        async function fetchJson(url) {
            try {
                const res = await fetch(url);
                const body = await res.json().catch(() => null);
                if (!res.ok) {
                    const msg = body && body.error ? body.error : `Request failed: ${res.status}`;
                    return { error: msg };
                }
                return { data: body };
            } catch (err) {
                console.error(err);
                return { error: err.message || 'Network error' };
            }
        }

        function escapeHtml(value) {
            const div = document.createElement('div');
            div.textContent = value ?? '';
            return div.innerHTML;
        }

        function renderError(message) {
            detailsArea.innerHTML = `<div class="alert alert-danger">${escapeHtml(message)}</div>`;
        }

        function renderList(items, type) {
            itemList.innerHTML = '';
            listTitle.textContent = type === 'groups' ? 'Groups' : 'Users';
            items.forEach(i => {
                const li = document.createElement('li');
                li.className = 'list-group-item list-group-item-action';
                li.textContent = i.name;
                li.dataset.dn = i.dn;
                li.style.cursor = 'pointer';
                li.addEventListener('click', () => onSelectItem(i.dn, i.name, type));
                itemList.appendChild(li);
            });
        }

        function renderRelatedList(items, onClick, emptyMessage) {
            if (!items.length) {
                detailsArea.innerHTML = `<div class="alert alert-info">${escapeHtml(emptyMessage)}</div>`;
                return;
            }
            const ul = document.createElement('ul');
            ul.className = 'list-group';
            items.forEach(i => {
                const li = document.createElement('li');
                li.className = onClick ? 'list-group-item list-group-item-action' : 'list-group-item';
                li.textContent = i.name;
                if (onClick) {
                    li.dataset.dn = i.dn;
                    li.style.cursor = 'pointer';
                    li.addEventListener('click', () => onClick(i.dn, i.name));
                }
                ul.appendChild(li);
            });
            detailsArea.innerHTML = '';
            detailsArea.appendChild(ul);
        }

        async function loadAndRender(url, onClick, loadingText, emptyMessage, errorPrefix) {
            detailsArea.innerHTML = `<div class="text-muted">${escapeHtml(loadingText)}</div>`;
            const result = await fetchJson(url);
            if (result.error) {
                renderError(`${errorPrefix}: ${result.error}`);
                return;
            }
            renderRelatedList(result.data, onClick, emptyMessage);
        }

        async function onSelectItem(dn, name, type) {
            clearDetails();
            if (type === 'groups') {
                detailTitle.textContent = 'Users in ' + name;
                await loadAndRender(
                    `/Admin/GetUsersInGroup?groupDn=${encodeURIComponent(dn)}`,
                    onSelectUserFromGroup,
                    'Loading users...',
                    'No users in this group',
                    'Failed to load users for this group'
                );
            } else {
                detailTitle.textContent = 'Groups of ' + name;
                await loadAndRender(
                    `/Admin/GetGroupsForUser?userDn=${encodeURIComponent(dn)}`,
                    null,
                    'Loading groups...',
                    'User is not a member of any groups',
                    'Failed to load groups for this user'
                );
            }
        }

        async function onSelectUserFromGroup(dn, name) {
            detailTitle.textContent = name + ' — groups';
            await loadAndRender(
                `/Admin/GetGroupsForUser?userDn=${encodeURIComponent(dn)}`,
                null,
                'Loading groups...',
                'No groups for this user',
                'Failed to load groups for this user'
            );
        }

        loadBtn.addEventListener('click', async () => {
            const view = viewSelect.value;
            const q = filterInput.value;
            clearDetails();

            const isGroups = view === 'groups';
            detailTitle.textContent = isGroups ? 'Select a group' : 'Select a user';
            detailsArea.innerHTML = isGroups
                ? '<div class="text-muted">Choose a group to see members</div>'
                : '<div class="text-muted">Choose a user to see groups</div>';

            const url = isGroups
                ? `/Admin/GetGroups?q=${encodeURIComponent(q)}`
                : `/Admin/GetUsers?q=${encodeURIComponent(q)}`;
            const errorPrefix = isGroups
                ? 'Failed to load groups from directory'
                : 'Failed to load users from directory';

            const result = await fetchJson(url);
            if (result.error) {
                itemList.innerHTML = '';
                renderError(`${errorPrefix}: ${result.error}`);
                return;
            }
            renderList(result.data, isGroups ? 'groups' : 'users');
        });
    </script>
}
