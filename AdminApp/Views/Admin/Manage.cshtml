@{
    Layout = "_Layout";
}

<h2 class="mb-4">Manage Directory - Groups / Users</h2>

<div class="mb-3">
    <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">← Pending Registrations</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label">View</label>
                    <select id="viewSelect" class="form-select">
                        <option value="groups">Groups</option>
                        <option value="users">Users</option>
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Filter</label>
                    <input id="filterInput" class="form-control" placeholder="search by name" />
                </div>

                <div class="d-grid">
                    <button id="loadBtn" class="btn btn-primary">Load</button>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h5 id="listTitle">Groups</h5>
                <ul id="itemList" class="list-group list-group-flush" style="max-height:60vh; overflow:auto"></ul>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 id="detailTitle" class="mb-0">Details</h5>
                    <div>
                        <button id="topAddBtn" type="button" class="btn btn-outline-primary btn-sm d-none me-2">
                            + Hinzufügen
                        </button>
                        <button id="resetPasswordBtn" type="button" class="btn btn-warning btn-sm d-none">
                            🔑 Reset Password
                        </button>
                    </div>
                </div>
                <div id="detailsArea">Select a group or user to load related items.</div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reset Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="resetPasswordError" class="alert alert-danger d-none"></div>
                <p>
                    Soll das Passwort für <strong id="resetPasswordUserName"></strong> zurückgesetzt werden?
                </p>
                <p class="text-muted small mb-3">
                    An die unten eingetragene E-Mail-Adresse wird ein Reset-Link verschickt.
                    Der Link ist 24 Stunden gültig und kann nur einmal verwendet werden.
                    Die E-Mail-Adresse wird nicht gespeichert.
                </p>
                <div class="mb-3">
                    <label for="resetPasswordEmail" class="form-label">E-Mail-Adresse</label>
                    <input type="email" id="resetPasswordEmail" class="form-control" required />
                    <div id="resetPasswordEmailHint" class="form-text"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" id="resetPasswordConfirmBtn" class="btn btn-warning">Reset-Link senden</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="addToModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addToModalTitle">Hinzufügen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="addToError" class="alert alert-danger d-none"></div>
                <div class="mb-3">
                    <label class="form-label" id="addToSearchLabel">Suchen</label>
                    <div class="input-group">
                        <input type="text" id="addToSearchInput" class="form-control" />
                        <button class="btn btn-outline-secondary" id="addToSearchBtn">Suchen</button>
                    </div>
                </div>
                <ul id="addToResultList" class="list-group list-group-flush" style="max-height:40vh; overflow:auto"></ul>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="removeConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Entfernen bestätigen</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="removeConfirmMessage" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Abbrechen</button>
                <button type="button" id="removeConfirmBtn" class="btn btn-danger">Entfernen</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const loadBtn = document.getElementById('loadBtn');
        const viewSelect = document.getElementById('viewSelect');
        const filterInput = document.getElementById('filterInput');
        const itemList = document.getElementById('itemList');
        const detailTitle = document.getElementById('detailTitle');
        const detailsArea = document.getElementById('detailsArea');
        const listTitle = document.getElementById('listTitle');
        const topAddBtn = document.getElementById('topAddBtn');
        const resetPasswordBtn = document.getElementById('resetPasswordBtn');
        const resetPasswordModalEl = document.getElementById('resetPasswordModal');
        const resetPasswordModal = new bootstrap.Modal(resetPasswordModalEl);
        const resetPasswordUserName = document.getElementById('resetPasswordUserName');
        const resetPasswordEmail = document.getElementById('resetPasswordEmail');
        const resetPasswordEmailHint = document.getElementById('resetPasswordEmailHint');
        const resetPasswordError = document.getElementById('resetPasswordError');
        const resetPasswordConfirmBtn = document.getElementById('resetPasswordConfirmBtn');

        const addToModalEl = document.getElementById('addToModal');
        const addToModal = addToModalEl ? new bootstrap.Modal(addToModalEl) : null;
        const addToModalTitle = document.getElementById('addToModalTitle');
        const addToSearchLabel = document.getElementById('addToSearchLabel');
        const addToSearchInput = document.getElementById('addToSearchInput');
        const addToSearchBtn = document.getElementById('addToSearchBtn');
        const addToResultList = document.getElementById('addToResultList');
        const addToError = document.getElementById('addToError');

        const removeConfirmModalEl = document.getElementById('removeConfirmModal');
        const removeConfirmModal = removeConfirmModalEl ? new bootstrap.Modal(removeConfirmModalEl) : null;
        const removeConfirmMessage = document.getElementById('removeConfirmMessage');
        const removeConfirmBtn = document.getElementById('removeConfirmBtn');

        let removePendingAction = null;

        let selectedUser = null;
        let selectedGroup = null;
        let currentAddMode = null;

        function setSelectedUser(user) {
            selectedUser = user;
            if (user) {
                resetPasswordBtn.classList.remove('d-none');
            } else {
                resetPasswordBtn.classList.add('d-none');
            }
        }

        function clearDetails() {
            detailsArea.innerHTML = '';
            setSelectedUser(null);
            selectedGroup = null;
            topAddBtn.classList.add('d-none');
        }

        async function fetchJson(url) {
            try {
                const res = await fetch(url);
                const body = await res.json().catch(() => null);
                if (!res.ok) {
                    const msg = body && body.error ? body.error : `Request failed: ${res.status}`;
                    return { error: msg };
                }
                return { data: body };
            } catch (err) {
                console.error(err);
                return { error: err.message || 'Network error' };
            }
        }

        function escapeHtml(value) {
            const div = document.createElement('div');
            div.textContent = value ?? '';
            return div.innerHTML;
        }

        function renderError(message) {
            detailsArea.innerHTML = `<div class="alert alert-danger">${escapeHtml(message)}</div>`;
        }

        function makeUserRow(user, onRowClick, onRemoveClick) {
            const li = document.createElement('li');
            li.className = 'list-group-item d-flex justify-content-between align-items-center';
            li.dataset.dn = user.dn;

            const label = document.createElement('span');
            label.textContent = user.name;
            label.style.flex = '1 1 auto';
            label.style.overflow = 'hidden';
            label.style.textOverflow = 'ellipsis';
            if (onRowClick) {
                label.style.cursor = 'pointer';
                label.addEventListener('click', () => onRowClick(user.dn, user.name));
            }

            li.appendChild(label);
            
            if (onRemoveClick) {
                const btn = document.createElement('button');
                btn.className = 'btn btn-sm btn-outline-danger ms-2';
                btn.innerHTML = '🗑️';
                btn.title = 'Entfernen';
                btn.onclick = (e) => {
                    e.stopPropagation();
                    onRemoveClick(user.dn, user.name);
                };
                li.appendChild(btn);
            }

            return li;
        }

        function renderList(items, type) {
            itemList.innerHTML = '';
            listTitle.textContent = type === 'groups' ? 'Groups' : 'Users';
            items.forEach(i => {
                if (type === 'users') {
                    itemList.appendChild(makeUserRow(i, (dn, name) => onSelectItem(dn, name, 'users')));
                    return;
                }

                const li = document.createElement('li');
                li.className = 'list-group-item list-group-item-action';
                li.textContent = i.name;
                li.dataset.dn = i.dn;
                if (i.description) {
                    li.title = i.description;
                }
                li.style.cursor = 'pointer';
                li.addEventListener('click', () => onSelectItem(i.dn, i.name, type));
                itemList.appendChild(li);
            });
        }

        function renderRelatedList(items, onClick, emptyMessage, isUsers) {
            detailsArea.innerHTML = '';
            
            if (!items.length) {
                detailsArea.innerHTML = `<div class="alert alert-info">${escapeHtml(emptyMessage)}</div>`;
            } else {
                const ul = document.createElement('ul');
                ul.className = 'list-group mb-3';
                items.forEach(i => {
                    if (isUsers) {
                        ul.appendChild(makeUserRow(i, onClick, () => removeUserFromSelectedGroup(i.dn, i.name)));
                    } else {
                        const li = document.createElement('li');
                        li.className = onClick ? 'list-group-item list-group-item-action d-flex justify-content-between align-items-center' : 'list-group-item d-flex justify-content-between align-items-center';
                        
                        const label = document.createElement('span');
                        label.textContent = i.name;
                        label.style.flex = '1 1 auto';
                        if (onClick) {
                            li.style.cursor = 'pointer';
                            label.addEventListener('click', () => onClick(i.dn, i.name));
                        }
                        li.appendChild(label);
                        
                        if (selectedUser) {
                            const btn = document.createElement('button');
                            btn.className = 'btn btn-sm btn-outline-danger ms-2';
                            btn.innerHTML = '🗑️';
                            btn.title = 'Entfernen';
                            btn.onclick = (e) => {
                                e.stopPropagation();
                                removeGroupFromSelectedUser(i.dn, i.name);
                            };
                            li.appendChild(btn);
                        }

                        ul.appendChild(li);
                    }
                });
                detailsArea.appendChild(ul);
            }
        }

        async function loadAndRender(url, onClick, loadingText, emptyMessage, errorPrefix, isUsers) {
            detailsArea.innerHTML = `<div class="text-muted">${escapeHtml(loadingText)}</div>`;
            const result = await fetchJson(url);
            if (result.error) {
                renderError(`${errorPrefix}: ${result.error}`);
                return;
            }
            renderRelatedList(result.data, onClick, emptyMessage, isUsers);
        }

        async function onSelectItem(dn, name, type) {
            clearDetails();
            if (type === 'groups') {
                selectedGroup = { dn, name };
                detailTitle.textContent = 'Users in ' + name;
                topAddBtn.textContent = '+ Nutzer hinzufügen';
                topAddBtn.onclick = () => openAddModal('users');
                topAddBtn.classList.remove('d-none');
                await loadAndRender(
                    `/Admin/GetUsersInGroup?groupDn=${encodeURIComponent(dn)}`,
                    onSelectUserFromGroup,
                    'Loading users...',
                    'No users in this group',
                    'Failed to load users for this group',
                    true
                );
            } else {
                setSelectedUser({ dn, name });
                detailTitle.textContent = 'Groups of ' + name;
                topAddBtn.textContent = '+ Gruppe hinzufügen';
                topAddBtn.onclick = () => openAddModal('groups');
                topAddBtn.classList.remove('d-none');
                await loadAndRender(
                    `/Admin/GetGroupsForUser?userDn=${encodeURIComponent(dn)}`,
                    null,
                    'Loading groups...',
                    'User is not a member of any groups',
                    'Failed to load groups for this user',
                    false
                );
            }
        }

        async function onSelectUserFromGroup(dn, name) {
            clearDetails();
            selectedGroup = null;
            setSelectedUser({ dn, name });
            detailTitle.textContent = name + ' — groups';
            topAddBtn.textContent = '+ Gruppe hinzufügen';
            topAddBtn.onclick = () => openAddModal('groups');
            topAddBtn.classList.remove('d-none');
            await loadAndRender(
                `/Admin/GetGroupsForUser?userDn=${encodeURIComponent(dn)}`,
                null,
                'Loading groups...',
                'No groups for this user',
                'Failed to load groups for this user',
                false
            );
        }

        async function openResetPasswordDialog(dn, name) {
            setSelectedUser({ dn, name });
            resetPasswordError.classList.add('d-none');
            resetPasswordError.textContent = '';
            resetPasswordUserName.textContent = name;
            resetPasswordEmail.value = '';
            resetPasswordEmailHint.textContent = 'Lade hinterlegte E-Mail-Adresse...';
            resetPasswordConfirmBtn.disabled = true;
            resetPasswordModal.show();

            const result = await fetchJson(`/Admin/GetUserDetails?userDn=${encodeURIComponent(dn)}`);
            if (result.error) {
                resetPasswordEmailHint.textContent = '';
                resetPasswordError.textContent = result.error;
                resetPasswordError.classList.remove('d-none');
                resetPasswordConfirmBtn.disabled = false;
                return;
            }

            const mail = result.data && result.data.mail ? result.data.mail : '';
            resetPasswordEmail.value = mail;
            resetPasswordEmailHint.textContent = mail
                ? 'Hinterlegte E-Mail-Adresse aus dem Verzeichnis. Du kannst sie hier anpassen.'
                : 'Es ist keine E-Mail-Adresse hinterlegt – bitte trage eine ein.';
            resetPasswordConfirmBtn.disabled = false;
        }

        resetPasswordBtn.addEventListener('click', () => {
            if (!selectedUser) return;
            openResetPasswordDialog(selectedUser.dn, selectedUser.name);
        });

        resetPasswordConfirmBtn.addEventListener('click', async () => {
            if (!selectedUser) return;
            const email = resetPasswordEmail.value.trim();
            resetPasswordError.classList.add('d-none');
            resetPasswordError.textContent = '';

            if (!email) {
                resetPasswordError.textContent = 'Bitte eine E-Mail-Adresse eingeben.';
                resetPasswordError.classList.remove('d-none');
                return;
            }

            resetPasswordConfirmBtn.disabled = true;
            try {
                const body = new URLSearchParams();
                body.append('userDn', selectedUser.dn);
                body.append('email', email);

                const res = await fetch('/Admin/SendPasswordReset', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: body.toString()
                });
                const payload = await res.json().catch(() => null);

                if (!res.ok) {
                    const msg = (payload && payload.error) ? payload.error : `Request failed: ${res.status}`;
                    resetPasswordError.textContent = msg;
                    resetPasswordError.classList.remove('d-none');
                    return;
                }

                resetPasswordModal.hide();
                detailsArea.insertAdjacentHTML('afterbegin',
                    `<div class="alert alert-success">Reset-Link wurde an ${escapeHtml(email)} gesendet.</div>`);
            } catch (err) {
                resetPasswordError.textContent = err.message || 'Netzwerkfehler';
                resetPasswordError.classList.remove('d-none');
            } finally {
                resetPasswordConfirmBtn.disabled = false;
            }
        });

        loadBtn.addEventListener('click', async () => {
            const view = viewSelect.value;
            const q = filterInput.value;
            clearDetails();

            const isGroups = view === 'groups';
            detailTitle.textContent = isGroups ? 'Select a group' : 'Select a user';
            detailsArea.innerHTML = isGroups
                ? '<div class="text-muted">Choose a group to see members</div>'
                : '<div class="text-muted">Choose a user to see groups</div>';

            const url = isGroups
                ? `/Admin/GetGroups?q=${encodeURIComponent(q)}`
                : `/Admin/GetUsers?q=${encodeURIComponent(q)}`;
            const errorPrefix = isGroups
                ? 'Failed to load groups from directory'
                : 'Failed to load users from directory';

            const result = await fetchJson(url);
            if (result.error) {
                itemList.innerHTML = '';
                renderError(`${errorPrefix}: ${result.error}`);
                return;
            }
            renderList(result.data, isGroups ? 'groups' : 'users');
        });

        function removeUserFromSelectedGroup(userDn, userName) {
            removeConfirmMessage.textContent = `Möchtest du ${userName} wirklich aus ${selectedGroup.name} entfernen?`;
            removePendingAction = async () => {
                removeConfirmBtn.disabled = true;
                const res = await fetch('/Admin/RemoveUserFromGroup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ userDn, groupDn: selectedGroup.dn }).toString()
                });
                const data = await res.json().catch(() => null);
                removeConfirmBtn.disabled = false;
                if (!res.ok) alert(data?.error || 'Fehler beim Entfernen');
                else {
                    removeConfirmModal.hide();
                    onSelectItem(selectedGroup.dn, selectedGroup.name, 'groups');
                }
            };
            removeConfirmModal.show();
        }

        function removeGroupFromSelectedUser(groupDn, groupName) {
            removeConfirmMessage.textContent = `Möchtest du ${selectedUser.name} wirklich aus ${groupName} entfernen?`;
            removePendingAction = async () => {
                removeConfirmBtn.disabled = true;
                const res = await fetch('/Admin/RemoveUserFromGroup', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ userDn: selectedUser.dn, groupDn }).toString()
                });
                const data = await res.json().catch(() => null);
                removeConfirmBtn.disabled = false;
                if (!res.ok) alert(data?.error || 'Fehler beim Entfernen');
                else {
                    removeConfirmModal.hide();
                    onSelectItem(selectedUser.dn, selectedUser.name, 'users');
                }
            };
            removeConfirmModal.show();
        }

        if (removeConfirmBtn) {
            removeConfirmBtn.addEventListener('click', () => {
                if (removePendingAction) removePendingAction();
            });
        }

        function openAddModal(type) {
            currentAddMode = type;
            addToError.classList.add('d-none');
            addToSearchInput.value = '';
            addToResultList.innerHTML = '';
            if (type === 'groups') {
                addToModalTitle.textContent = `Gruppe zu ${selectedUser.name} hinzufügen`;
                addToSearchLabel.textContent = 'Gruppen suchen';
            } else {
                addToModalTitle.textContent = `Nutzer zu ${selectedGroup.name} hinzufügen`;
                addToSearchLabel.textContent = 'Nutzer suchen';
            }
            addToModal.show();
        }

        if (addToSearchBtn) {
            addToSearchBtn.addEventListener('click', async () => {
                const q = addToSearchInput.value;
                addToError.classList.add('d-none');
                addToResultList.innerHTML = '<li class="list-group-item text-muted">Lädt...</li>';

                const url = currentAddMode === 'groups'
                    ? `/Admin/GetGroups?q=${encodeURIComponent(q)}`
                    : `/Admin/GetUsers?q=${encodeURIComponent(q)}`;

                const res = await fetchJson(url);
                if (res.error) {
                    addToError.textContent = res.error;
                    addToError.classList.remove('d-none');
                    addToResultList.innerHTML = '';
                    return;
                }

                addToResultList.innerHTML = '';
                if (!res.data || res.data.length === 0) {
                    addToResultList.innerHTML = '<li class="list-group-item text-muted">Keine Treffer gefunden</li>';
                    return;
                }

                res.data.forEach(i => {
                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex justify-content-between align-items-center';
                    li.textContent = i.name;
                    
                    const btn = document.createElement('button');
                    btn.className = 'btn btn-sm btn-primary ms-2';
                    btn.textContent = 'Hinzufügen';
                    btn.onclick = () => performAdd(i.dn);
                    
                    li.appendChild(btn);
                    addToResultList.appendChild(li);
                });
            });
        }

        addToSearchInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                addToSearchBtn.click();
            }
        });

        async function performAdd(dn) {
            const userDn = currentAddMode === 'groups' ? selectedUser.dn : dn;
            const groupDn = currentAddMode === 'groups' ? dn : selectedGroup.dn;

            const res = await fetch('/Admin/AddUserToGroup', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ userDn, groupDn }).toString()
            });
            const data = await res.json().catch(() => null);
            
            if (!res.ok) {
                addToError.textContent = data?.error || 'Fehler beim Hinzufügen';
                addToError.classList.remove('d-none');
            } else {
                addToModal.hide();
                if (currentAddMode === 'groups') {
                    onSelectItem(selectedUser.dn, selectedUser.name, 'users');
                } else {
                    onSelectItem(selectedGroup.dn, selectedGroup.name, 'groups');
                }
            }
        }
    </script>
}
