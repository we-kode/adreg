@{
    Layout = "_Layout";
}

<h2>Create Directory Group</h2>

<div class="card mt-3 shadow-sm">
    <div class="card-body">

        <form method="post" asp-action="CreateGroup">

            <div class="mb-3">
                <label>Group Name</label>
                <input name="name" class="form-control" placeholder="CN for the group" required />
            </div>

            <button class="btn btn-primary">Create Group</button>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>

        </form>

    </div>
</div>