@using Shared.Models
@{
    Layout = "_Layout";
    var groups = ViewBag.Groups as List<DirectoryItem> ?? new List<DirectoryItem>();
}

<h2>Create Registration Link</h2>

<div class="card mt-3 shadow-sm">
    <div class="card-body">

        <form method="post" asp-action="CreateLink">

            <div class="mb-3">
                <label>Valid Until (optional)</label>
                <input type="datetime-local" name="validUntil" class="form-control" />
                <small class="form-text text-muted">Leave empty for no expiration</small>
            </div>

            <div class="form-check mb-3">
                <input type="checkbox" name="singleUse" class="form-check-input" checked />
                <label class="form-check-label">Single Use</label>
            </div>

            <div class="mb-3">
                <label>Email recipient</label>
                <input type="email" name="email" class="form-control" placeholder="user@example.com" required />
            </div>

            <div class="mb-3">
                <label>Directory Groups</label>
                <select name="selectedGroups" class="form-select" multiple size="8">
                    @foreach (var g in groups)
                    {
                        <option value="@g.Dn">@g.Name</option>
                    }
                </select>
                <small class="form-text text-muted">Ctrl+Click to select multiple</small>
            </div>

            <button class="btn btn-primary">
                Create &amp; Send Link
            </button>

            <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>

        </form>

    </div>
</div>
