@{
    Layout = "_Layout";
    var groups = ViewBag.Groups as List<(string Oid, string Name)>;
}

<h2>Create Registration Link</h2>

<div class="card mt-3 shadow-sm">
    <div class="card-body">

        <form method="post" asp-action="CreateLink">

            <div class="mb-3">
                <label>Valid Until</label>
                <input type="datetime-local" name="validUntil" class="form-control" required />
            </div>

            <div class="form-check mb-3">
                <input type="checkbox" name="singleUse" class="form-check-input" />
                <label class="form-check-label">Single Use</label>
            </div>

            <div class="mb-3">
                <label>Email recipient</label>
                <input type="email" name="email" class="form-control" placeholder="user@example.com" required />
            </div>

            <div class="mb-3">
                <label>AD Groups</label>
                <select name="selectedGroups" class="form-select" multiple size="5">
                    @foreach (var g in (groups ?? []))
                    {
                        <option value="@g.Oid">@g.Name</option>
                    }
                </select>
                <small class="form-text text-muted">Ctrl+Click to select multiple</small>
            </div>

            <button class="btn btn-primary">
                Create & Send Link
            </button>

        </form>

    </div>
</div>